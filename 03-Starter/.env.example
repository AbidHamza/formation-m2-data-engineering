# Copier ce fichier en .env et remplir les valeurs.
# NE JAMAIS commiter le .env (il est dans .gitignore) — règle RGPD/sécurité.

# France Travail — https://francetravail.io (créer une application, API Offres d'emploi v2)
FT_CLIENT_ID=
FT_CLIENT_SECRET=

# Supabase (atelier 2+) — https://supabase.com (Project Settings > API)
SUPABASE_URL=
SUPABASE_KEY=

# Anthropic / Claude (atelier 5) — https://console.anthropic.com
ANTHROPIC_API_KEY=

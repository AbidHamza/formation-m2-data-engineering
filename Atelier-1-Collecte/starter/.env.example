# Cles de l'API France Travail (https://francetravail.io)
# Cree une application, demande l'acces a "Offres d'emploi v2", recupere tes cles,
# puis copie ce fichier en .env (dans corrige/) et remplis les valeurs.
FT_CLIENT_ID=PAR_xxxxxxxx
FT_CLIENT_SECRET=xxxxxxxx

# Atelier 2 : chaine de connexion Postgres / Supabase (onglet Connect de Supabase)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Atelier enrichment (optionnel) : cle Hunter.io ou equivalent
HUNTER_API_KEY=
